# Ottenuto da @BotFather su Telegram
BOT_TOKEN=

# Da console.groq.com (gratuito, no carta di credito)
GROQ_API_KEY=

# JSON del service account Google (tutto su una riga)
# Scaricato da Google Cloud Console → Service Accounts → Chiavi
GOOGLE_CREDENTIALS_JSON=

# ID del Google Sheet (si trova nell'URL: docs.google.com/spreadsheets/d/QUESTO_ID/edit)
SPREADSHEET_ID=

# Il tuo Telegram user ID numerico (trovalo con @userinfobot)
AUTHORIZED_USER_ID=
